# Example environment for a dev Hermes assistant service.
# Copy to a host-owned secret path such as /etc/sandboxed-sh/hermes-assistant-dev.env
# and fill in the values on the deployment host. Do not commit the real file.

# Sandboxed.sh control plane used by assistant-mcp.
HERMES_SANDBOXED_API_URL=https://agent-backend-dev.thomas.md
HERMES_SANDBOXED_API_TOKEN=
HERMES_DEFAULT_WORKSPACE_ID=

# Sandboxed.sh OpenAI-compatible model proxy for Hermes.
HERMES_MODEL_BASE_URL=https://agent-backend-dev.thomas.md/v1
HERMES_MODEL_API_KEY=
HERMES_MODEL=builtin/assistant

# Messaging gateway secrets belong to the Hermes runtime, not assistant-mcp.
HERMES_TELEGRAM_BOT_TOKEN=
HERMES_TELEGRAM_ALLOWED_USER_IDS=

# Stdio MCP bridge exposed by this repository.
HERMES_ASSISTANT_MCP_COMMAND=/usr/local/bin/assistant-mcp
